<% content_for :title, "Pessoas" %>

<h1 class="text-center mb-4 mt-4">Pessoas</h1>

<div id="pessoas" class="d-flex flex-wrap gap-4 justify-content-center">
  <% @pessoas.each do |pessoa| %>
    <div class="card text-white bg-primary mb-3" style="max-width: 20rem;">
      <div class="card-body d-flex flex-column">
        <h5 class="card-title"><%= pessoa.nome %> <%= pessoa.sobrenome %></h5>
        <p class="card-text">Documento nº: <%= pessoa.documento&.numero || '—' %></p>
        <%= link_to 'Ver', pessoa_path(pessoa), class: 'btn btn-secondary mt-auto' %>
      </div>
    </div>
  <% end %>
</div>

<% if policy(Pessoa).create? %>
  <div class="mt-4 text-center">
    <%= link_to "Criar nova pessoa", new_pessoa_path, class: 'btn btn-outline-primary' %>
  </div>
<% end %>
