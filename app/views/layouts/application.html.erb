<!DOCTYPE html>
<html>
  <head>
    <title>Sistema de Gestão</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag 'bootstrap.min.css', media: 'all' %>
    <%= stylesheet_link_tag "https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css", rel: "stylesheet" %>
    <%= stylesheet_link_tag 'application', media: 'all' %>
    <%= javascript_importmap_tags %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-..." crossorigin="anonymous" defer></script>


  </head>
  <body>
    
    <%= render "layouts/navbar" %>

    <main>
      <%= yield %>
    </main>

    <%= javascript_importmap_tags %>
  </body>
</html>
