<div class="container mt-5 d-flex justify-content-center">
  <div class="card shadow-lg p-4" style="max-width: 500px; width: 100%;">
    <h2 class="text-center text-primary mb-4">Recuperar Senha</h2>

    <%= form_with(model: resource, as: resource_name, url: password_path(resource_name), local: true) do |f| %>

      <div class="mb-3">
        <%= f.label :email, "Informe seu e-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", required: true %>
      </div>

      <div class="d-grid gap-2 mb-3">
        <%= f.submit "Enviar instruções de recuperação", class: "btn btn-primary" %>
      </div>

      <div class="text-center">
        <%= link_to "Voltar para o login", new_session_path(resource_name), class: "btn btn-link" %>
      </div>

    <% end %>
  </div>
</div>
