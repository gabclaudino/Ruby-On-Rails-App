<div class="container mt-5 d-flex justify-content-center">
  <div class="card shadow-lg p-4" style="max-width: 500px; width: 100%;">
    <h2 class="text-center text-primary mb-4">Criar Conta</h2>

    <%= form_with(model: resource, as: resource_name, url: registration_path(resource_name), class: "needs-validation", local: true) do |f| %>
      
      <div class="mb-3">
        <%= f.label :email, "E-mail", class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password, "Senha", class: "form-label" %>
        <%= f.password_field :password, autocomplete: "new-password", class: "form-control", required: true %>
      </div>

      <div class="mb-3">
        <%= f.label :password_confirmation, "Confirmar Senha", class: "form-label" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control", required: true %>
      </div>

      <div class="d-grid gap-2 mb-3">
        <%= f.submit "Cadastrar", class: "btn btn-primary" %>
      </div>

      <div class="text-center">
        <%= link_to "Já tem conta? Entrar", new_session_path(resource_name), class: "btn btn-link" %>
      </div>

    <% end %>
  </div>
</div>
