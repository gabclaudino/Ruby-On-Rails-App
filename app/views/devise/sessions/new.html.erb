<div class="container d-flex align-items-center justify-content-center mt-5">
  <div class="card shadow-lg" style="max-width: 500px; width: 100%;">
    <div class="card-body">
      <h2 class="text-center text-primary mb-4">Entrar</h2>

      <%= form_with scope: :user, url: session_path(:user), method: :post, local: true do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, class: "form-control", placeholder: "Digite seu email" %>
        </div>

        <div class="mb-3">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "Digite sua senha" %>
        </div>

        <div class="form-check mb-3">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, "Lembrar-me", class: "form-check-label" %>
        </div>

        <div class="d-grid">
          <%= f.submit "Entrar", class: "btn btn-primary" %>
        </div>
      <% end %>

      <hr>

      <div class="text-center">
        <%= link_to "Esqueceu sua senha?", new_user_password_path, class: "small" %><br>
        <%= link_to "Não tem uma conta? Cadastre-se", new_user_registration_path, class: "small" %>
      </div>
    </div>
  </div>
</div>
